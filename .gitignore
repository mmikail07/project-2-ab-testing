# Generated experiment data (regenerate with python scripts/run_all.py)
# Large parquet is excluded; small summary CSV + ground_truth JSON are committed
# as reference artifacts so a clone can read the truth without rerunning.
data/raw/*
data/interim/*
data/processed/*.parquet
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/processed/experiment_summary.csv
!data/processed/ground_truth.json

